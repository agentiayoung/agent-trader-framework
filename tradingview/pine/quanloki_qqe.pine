//@version=6
strategy("Quanloki QQE System - Opposite Signal Only + Points", overlay=true,
     initial_capital=100000,
     pyramiding=0,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     slippage=1,
     process_orders_on_close=true)

// === Inputs ===
RSI_Period = input.int(14, "RSI Length")
SF = input.int(5, "RSI Smoothing")
QQE = input.float(4.238, "Fast QQE Factor")

showLabels = input.bool(true, "Pokaż etykiety BUY/SELL")
showStats = input.bool(true, "Pokaż tabelę punktów")

entryPriceType = input.string("close", "Entry Price", options=["open", "close"])

// === Core QQE ===
src = close
Wilders_Period = RSI_Period * 2 - 1

Rsi = ta.rsi(src, RSI_Period)
RsiMa = ta.ema(Rsi, SF)
AtrRsi = math.abs(RsiMa[1] - RsiMa)
MaAtrRsi = ta.ema(AtrRsi, Wilders_Period)
dar = ta.ema(MaAtrRsi, Wilders_Period) * QQE

var float longband = na
var float shortband = na
var int trend = 0

DeltaFastAtrRsi = dar
RSIndex = RsiMa
newshortband = RSIndex + DeltaFastAtrRsi
newlongband = RSIndex - DeltaFastAtrRsi

longband := RSIndex[1] > nz(longband[1]) and RSIndex > nz(longband[1]) ? math.max(nz(longband[1]), newlongband) : newlongband
shortband := RSIndex[1] < nz(shortband[1]) and RSIndex < nz(shortband[1]) ? math.min(nz(shortband[1]), newshortband) : newshortband

cross_1 = ta.cross(longband[1], RSIndex)
trend := ta.cross(RSIndex, shortband[1]) ? 1 : cross_1 ? -1 : nz(trend[1], 1)

FastAtrRsiTL = trend == 1 ? longband : shortband

// === Signals ===
longSignal = FastAtrRsiTL < RSIndex and FastAtrRsiTL[1] >= RSIndex[1]
shortSignal = FastAtrRsiTL > RSIndex and FastAtrRsiTL[1] <= RSIndex[1]

// === Strategy entries/exits only by opposite signal ===
if longSignal
    strategy.close("SHORT")
    strategy.entry("LONG", strategy.long)

if shortSignal
    strategy.close("LONG")
    strategy.entry("SHORT", strategy.short)

// === Labels ===
if showLabels and longSignal
    label.new(bar_index, low,
         "BUY\n" + str.tostring(close, format.mintick),
         style=label.style_label_up,
         color=color.new(color.green, 0),
         textcolor=color.white,
         yloc=yloc.belowbar)

if showLabels and shortSignal
    label.new(bar_index, high,
         "SELL\n" + str.tostring(close, format.mintick),
         style=label.style_label_down,
         color=color.new(color.red, 0),
         textcolor=color.white,
         yloc=yloc.abovebar)

// === Points counting ===
var float totalPoints = 0.0
var float lastTradePoints = 0.0
var int closedTradesPrev = 0

if strategy.closedtrades > closedTradesPrev
    lastTradePoints := strategy.closedtrades.profit(strategy.closedtrades - 1) / syminfo.pointvalue
    totalPoints += lastTradePoints
    closedTradesPrev := strategy.closedtrades

openPoints = strategy.position_size > 0 ? close - strategy.position_avg_price :
     strategy.position_size < 0 ? strategy.position_avg_price - close : na

// === Stats Table ===
var table stats = table.new(position.top_right, 2, 7, border_width=1)

if showStats and barstate.islast
    winTrades = strategy.wintrades
    lossTrades = strategy.losstrades
    allTrades = strategy.closedtrades
    winrate = allTrades > 0 ? winTrades * 100.0 / allTrades : na

    table.cell(stats, 0, 0, "QQE SYSTEM", bgcolor=color.new(color.gray, 80), text_color=color.white)
    table.cell(stats, 1, 0, "WYNIK", bgcolor=color.new(color.gray, 80), text_color=color.white)

    table.cell(stats, 0, 1, "Suma pkt")
    table.cell(stats, 1, 1, str.tostring(totalPoints, format.mintick))

    table.cell(stats, 0, 2, "Ostatni trade")
    table.cell(stats, 1, 2, str.tostring(lastTradePoints, format.mintick))

    table.cell(stats, 0, 3, "Otwarte pkt")
    table.cell(stats, 1, 3, strategy.position_size != 0 ? str.tostring(openPoints, format.mintick) : "-")

    table.cell(stats, 0, 4, "Closed trades")
    table.cell(stats, 1, 4, str.tostring(allTrades))

    table.cell(stats, 0, 5, "Win / Loss")
    table.cell(stats, 1, 5, str.tostring(winTrades) + " / " + str.tostring(lossTrades))

    table.cell(stats, 0, 6, "Winrate")
    table.cell(stats, 1, 6, allTrades > 0 ? str.tostring(winrate, "#.##") + "%" : "-")

// === Alerts ===
alertcondition(longSignal, title="BUY", message="QQE BUY Signal")
alertcondition(shortSignal, title="SELL", message="QQE SELL Signal")