//@version=6
strategy("Ruptura de Rango Horario - Presbiter", overlay=true, max_boxes_count=100, max_labels_count=100)

// === CONFIGURACIÓN ===
sessionRange = input.session("0730-0800", "Rango operativo")
tz = input.string("America/Lima", "Zona horaria")

slTicks = input.int(50, "Stop Loss en ticks", minval=1)
tpTicks = input.int(100, "Take Profit en ticks", minval=1)
boxBars = input.int(20, "Extensión visual SL/TP en velas", minval=1)

// Filtro de días
tradeMon = input.bool(true, "Lunes")
tradeTue = input.bool(true, "Martes")
tradeWed = input.bool(true, "Miércoles")
tradeThu = input.bool(true, "Jueves")
tradeFri = input.bool(true, "Viernes")

// === DÍAS ACTIVOS ===
day = dayofweek(time)
allowedDay =
     day == dayofweek.monday    and tradeMon or
     day == dayofweek.tuesday   and tradeTue or
     day == dayofweek.wednesday and tradeWed or
     day == dayofweek.thursday  and tradeThu or
     day == dayofweek.friday    and tradeFri

// === DETECCIÓN DE SESIÓN ===
inRange = not na(time(timeframe.period, sessionRange, tz))
newDay = ta.change(time("D")) != 0

var float rangeHigh = na
var float rangeLow = na
var bool tradedToday = false
var box rangeBox = na

// Reset diario
if newDay
    rangeHigh := na
    rangeLow := na
    tradedToday := false
    rangeBox := na

// Construcción del rango
if inRange and allowedDay
    rangeHigh := na(rangeHigh) ? high : math.max(rangeHigh, high)
    rangeLow := na(rangeLow) ? low : math.min(rangeLow, low)

    if na(rangeBox)
        rangeBox := box.new(
             left=bar_index,
             top=rangeHigh,
             right=bar_index,
             bottom=rangeLow,
             bgcolor=color.new(color.blue, 85),
             border_color=color.blue
        )
    else
        box.set_right(rangeBox, bar_index)
        box.set_top(rangeBox, rangeHigh)
        box.set_bottom(rangeBox, rangeLow)

// === RUPTURA DESPUÉS DEL RANGO ===
rangeReady = not inRange and allowedDay and not na(rangeHigh) and not na(rangeLow) and not tradedToday

longSignal = rangeReady and barstate.isconfirmed and close > rangeHigh
shortSignal = rangeReady and barstate.isconfirmed and close < rangeLow

tick = syminfo.mintick

// === ENTRADA COMPRA ===
if longSignal
    entry = close
    sl = entry - slTicks * tick
    tp = entry + tpTicks * tick

    strategy.entry("BUY", strategy.long)
    strategy.exit("TP/SL BUY", "BUY", stop=sl, limit=tp)

    box.new(bar_index, entry, bar_index + boxBars, sl, bgcolor=color.new(color.red, 80), border_color=color.red)
    box.new(bar_index, tp, bar_index + boxBars, entry, bgcolor=color.new(color.green, 80), border_color=color.green)

    label.new(bar_index, low, "BUY", style=label.style_label_up, color=color.green, textcolor=color.white)
    tradedToday := true

// === ENTRADA VENTA ===
if shortSignal
    entry = close
    sl = entry + slTicks * tick
    tp = entry - tpTicks * tick

    strategy.entry("SELL", strategy.short)
    strategy.exit("TP/SL SELL", "SELL", stop=sl, limit=tp)

    box.new(bar_index, sl, bar_index + boxBars, entry, bgcolor=color.new(color.red, 80), border_color=color.red)
    box.new(bar_index, entry, bar_index + boxBars, tp, bgcolor=color.new(color.green, 80), border_color=color.green)

    label.new(bar_index, high, "SELL", style=label.style_label_down, color=color.red, textcolor=color.white)
    tradedToday := true