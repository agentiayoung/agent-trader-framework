// 5. FUNCTIONS
// ══════════════════════════════════════════════════════════

// Safe division — returns fallback if denominator is 0 or na
safeDiv(float num, float den, float fallback = 0.0) =>
    den != 0 and not na(num) and not na(den) ? num / den : fallback

// R² of linear regression vs time index — measures linearity (0-1)
// Uses correlation between price and bar index: R² = corr(price, n)²
rSquared(float src, int len) =>
    float corr = ta.correlation(src, bar_index, len)
    na(corr) ? 0.0 : math.pow(corr, 2)

// Auto HTF picker — 4× current timeframe
autoHtf() =>
    int curMin = timeframe.in_seconds(timeframe.period) / 60
    int targetMin = curMin * 4
    targetMin <= 5 ? "5" : targetMin <= 15 ? "15" : targetMin <= 30 ? "30" : targetMin <= 60 ? "60" : targetMin <= 240 ? "240" : targetMin <= 1440 ? "D" : "W"

// Format price safely (handles na with em-dash for display)
fmtPrice(float v) =>
    na(v) ? "—" : str.tostring(v, format.mintick)

// Format price for ALERTS (uses "n/a" instead of em-dash so it's
// JSON-safe and reads naturally in webhook payloads / Telegram).
fmtActive(float v) =>
    na(v) ? "n/a" : str.tostring(v, format.mintick)

// "+0.42%" / "-1.18%" suffix from entry. Returns empty when toggle off
// or values invalid. Used in SL/TP label text.
formatPctFromEntry(float level, float entry) =>
    string res = ""
    if showPctOnLabelsInput and not na(level) and not na(entry) and entry != 0
        float pct = (level - entry) / entry * 100.0
        string sign = pct >= 0 ? "+" : ""
        res := " (" + sign + str.tostring(pct, "#.##") + "%)"
    res

// Build a unicode-block progress gauge (e.g. "▰▰▰▰▰▱▱▱").
// `value` and `max` define the fill ratio; `width` is the number
// of glyphs to render. Capped at [0, width] internally.
//
// Premium feel comes from using ▰ (U+25B0) / ▱ (U+25B1) — clean,
// slightly rounded squares — instead of █/░ which look "pixel-art".
buildGauge(float value, float maxVal, int width) =>
    string result = ""
    int filledCount = maxVal <= 0 ? 0 : math.round(math.min(width, math.max(0.0, value / maxVal * width)))
    for i = 0 to width - 1
        result += i < filledCount ? "▰" : "▱"
    result

// Resolve font-size string to Pine's size.* constant
sizeFromString(string s) =>
    s == "Tiny"   ? size.tiny :
     s == "Small"  ? size.small :
     s == "Normal" ? size.normal :
     s == "Large"  ? size.large :
     s == "Huge"   ? size.huge :
     size.small

// Resolve line-style string to Pine's line.style_* constant
lineStyleFromString(string s) =>
    s == "Dashed" ? line.style_dashed :
     s == "Dotted" ? line.style_dotted :
     line.style_solid

// Position resolver
resolveDashPos(string s) =>
    s == "Top Left"     ? position.top_left :
     s == "Top Right"    ? position.top_right :
     s == "Bottom Left"  ? position.bottom_left :
     s == "Bottom Right" ? position.bottom_right :
     s == "Middle Right" ? position.middle_right :
     s == "Middle Left"  ? position.middle_left :
     position.top_right


