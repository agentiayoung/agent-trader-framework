// 17. ALERTS
// ══════════════════════════════════════════════════════════
// Active-trade levels (entry/SL/TP) vs Exit-snapshot levels:
//
// • Active alerts (BUY/SELL/FLIP) fire DURING a position's life — they
//   need current values: aSl/aTp1/... (uses fmtActive → "n/a" if na).
//
// • Exit alerts (SL hit, TP hit, BE activation) fire on the bar where
//   closure happens. By the time this section runs at end of script,
//   the position-reset block in section 10e has already cleared
//   activeXxx to na — so they read "n/a". Solution: section 10d
//   captured exitEntry/exitSL/exitTPx BEFORE the reset; this section
//   uses those snapshots.
//
// PERF: string concat is gated to the bar where the alert actually
// fires. Each prep block only runs on its trigger condition; otherwise
// thousands of unused strings would be built per chart load.

// Trigger gates
bool entryAlertFires = buyPasses or sellPasses
bool exitAlertFires  = slHit or tp1FirstTouch or tp2FirstTouch or tp3FirstTouch or beJustActivated

// ── ENTRY alerts (buy/sell/flip) ───────────────────────
if entryAlertFires
    string aPrice = str.tostring(close, format.mintick)
    string aSl    = fmtActive(activeSL)
    string aTp1   = fmtActive(activeTP1)
    string aTp2   = fmtActive(activeTP2)
    string aTp3   = fmtActive(activeTP3)
    string aRR    = str.tostring(currentRR, "#.#")
    string aTime  = str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone)
    string flipTag = flipDetected ? " (FLIP)" : ""
    string flipJsonBool = flipDetected ? "true" : "false"

    if buyPasses
        string buyText = "🟢 BUY [" + buyGrade + "]" + chopFlag + flipTag + " | " + syminfo.tickerid + " | TF: " + timeframe.period + " | Price: " + aPrice + " | SL: " + aSl + " | TP1: " + aTp1 + " | TP2: " + aTp2 + " | TP3: " + aTp3 + " | R:R: " + aRR + " | Regime: " + regimeLabel + " | Score: " + str.tostring(buyQuality, "#") + " | Time: " + aTime
        string buyJson = '{"action":"buy","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + aPrice + ',"sl":' + aSl + ',"tp1":' + aTp1 + ',"tp2":' + aTp2 + ',"tp3":' + aTp3 + ',"rr":' + aRR + ',"grade":"' + buyGrade + '","quality":' + str.tostring(buyQuality, "#") + ',"regime":"' + regimeLabel + '","choppy":' + (isChoppy ? "true" : "false") + ',"flip":' + flipJsonBool + '}'
        alert(webhookInput ? buyJson : buyText, alert.freq_once_per_bar_close)

    if sellPasses
        string sellText = "🔴 SELL [" + sellGrade + "]" + chopFlag + flipTag + " | " + syminfo.tickerid + " | TF: " + timeframe.period + " | Price: " + aPrice + " | SL: " + aSl + " | TP1: " + aTp1 + " | TP2: " + aTp2 + " | TP3: " + aTp3 + " | R:R: " + aRR + " | Regime: " + regimeLabel + " | Score: " + str.tostring(sellQuality, "#") + " | Time: " + aTime
        string sellJson = '{"action":"sell","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + aPrice + ',"sl":' + aSl + ',"tp1":' + aTp1 + ',"tp2":' + aTp2 + ',"tp3":' + aTp3 + ',"rr":' + aRR + ',"grade":"' + sellGrade + '","quality":' + str.tostring(sellQuality, "#") + ',"regime":"' + regimeLabel + '","choppy":' + (isChoppy ? "true" : "false") + ',"flip":' + flipJsonBool + '}'
        alert(webhookInput ? sellJson : sellText, alert.freq_once_per_bar_close)

    // Dedicated flip alert (in addition to the buy/sell alert above)
    if flipDetected and alertFlipInput
        string flipText = "🔄 POSITION FLIP " + flipFromDir + "→" + flipToDir + " | " + syminfo.tickerid + " | TF: " + timeframe.period + " | Prior Entry: " + fmtActive(flipFromEntry) + " | New Entry: " + aPrice + " | Time: " + aTime
        string flipJson = '{"action":"flip","from":"' + flipFromDir + '","to":"' + flipToDir + '","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","prior_entry":' + fmtActive(flipFromEntry) + ',"new_entry":' + aPrice + '}'
        alert(webhookInput ? flipJson : flipText, alert.freq_once_per_bar_close)

// ── EXIT alerts (SL/TP/BE) ─────────────────────────────
if exitAlertFires
    string eEntry = fmtActive(exitEntry)
    string eSL    = fmtActive(exitSL)
    string eTp1   = fmtActive(exitTP1)
    string eTp2   = fmtActive(exitTP2)
    string eTp3   = fmtActive(exitTP3)
    string aTime  = str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone)

    // SL hit — emoji differs by BE state.
    // exitBeActive captures whether BE was already active AT BAR START
    // (pre-mutation). A same-bar TP1+SL is impossible by design
    // (tp1FirstTouch requires not slHit), but using the snapshot is the
    // semantically correct query.
    if slHit and alertSlHitInput
        string slMsg = (exitBeActive ? "🛡️ BE STOP-OUT | " : "🛑 SL HIT | ") +
             syminfo.tickerid + " | Entry: " + eEntry + " | SL: " + eSL + " | Time: " + aTime
        alert(slMsg, alert.freq_once_per_bar_close)

    // BE activation alert — fires the bar TP1 is first touched and BE moves to entry
    if beJustActivated and alertTpHitInput
        alert("🛡️ BREAK-EVEN | " + syminfo.tickerid + " | SL moved to " + eEntry, alert.freq_once_per_bar_close)

    // TP hits — first-touch only.
    if tp1FirstTouch and alertTpHitInput
        alert("🎯 TP1 HIT | " + syminfo.tickerid + " | Price: " + eTp1, alert.freq_once_per_bar_close)
    if tp2FirstTouch and alertTpHitInput
        alert("🎯🎯 TP2 HIT | " + syminfo.tickerid + " | Price: " + eTp2, alert.freq_once_per_bar_close)
    if tp3FirstTouch and alertTpHitInput
        alert("🏆 TP3 HIT | " + syminfo.tickerid + " | Price: " + eTp3, alert.freq_once_per_bar_close)
