float atrVal = nz(ta.atr(atrLenInput), 0.0)

// Volatility regime: percentile rank of ATR over 100 bars
float volRank = useAdaptiveMultInput ? nz(ta.percentrank(atrVal, 100), 50.0) : 50.0

// Map volRank → multiplier adjustment:
// • Low vol  (rank < 30) → multiplier ×0.8
// • Mid vol  (30-70)     → multiplier ×1.0
// • High vol (rank > 70) → multiplier ×1.25
float multAdjust = useAdaptiveMultInput ? (volRank < 30 ? 0.8 : volRank > 70 ? 1.25 : 1.0) : 1.0
float effectiveMult = baseMultInput * multAdjust

// ── Synapse Trail (with optional ratchet) ─────────────
float trailCenter = ta.ema(close, trailLenInput)
float rawUpper    = trailCenter + atrVal * effectiveMult
float rawLower    = trailCenter - atrVal * effectiveMult

// Ratcheted bands — persistent state.
// Long mode: lowerBand only moves UP (never down) until flip.
// Short mode: upperBand only moves DOWN (never up) until flip.
// Direction flip resets the relevant band to its raw value.
// (No explicit init needed — the ratchet/legacy block below assigns
// both bands on every bar; var declaration ensures persistence for the
// [1] history reference used inside math.max/math.min.)
var float upperBand = na
var float lowerBand = na

// Direction: long when close above upper of prev bar, short when below lower
var int dir = 0
if isWarmedUp
    if close > nz(upperBand[1], close)
        dir := 1
    else if close < nz(lowerBand[1], close)
        dir := -1

// Apply ratchet OR free-running bands.
// dir[1] = direction on the previous (closed) bar; `dir` here is current.
// On a flip (dir != dir[1]) we seed the trail with the raw band value;
// otherwise we lock it monotonically (max for long lower, min for short upper).
bool dirFlipped = dir != nz(dir[1], 0)
if useRatchetInput
    if dir == 1
        lowerBand := dirFlipped ? rawLower : math.max(rawLower, nz(lowerBand[1], rawLower))
        upperBand := rawUpper
    else if dir == -1
        upperBand := dirFlipped ? rawUpper : math.min(rawUpper, nz(upperBand[1], rawUpper))
        lowerBand := rawLower
    else
        upperBand := rawUpper
        lowerBand := rawLower
else
    // Legacy v1.0.x behavior — bands recompute every bar
    upperBand := rawUpper
    lowerBand := rawLower

// Trail line displayed = lowerBand if long, upperBand if short
float trailLine = dir == 1 ? lowerBand : dir == -1 ? upperBand : na

// ── Raw direction-change signals ───────────────────────
bool rawBuy  = dir == 1  and dir[1] == -1 and isWarmedUp
bool rawSell = dir == -1 and dir[1] == 1  and isWarmedUp


// ══════════════════════════════════════════════════════════
// 7. MARKET REGIME ANALYSIS
// ══════════════════════════════════════════════════════════

// ── ADX (manual implementation — ta.dmi returns tuple) ─
[diPlus, diMinus, adxRaw] = ta.dmi(adxLenInput, adxLenInput)
float adxVal = nz(adxRaw, 0.0)
float adxScore = math.min(adxVal / 50.0 * 100.0, 100.0)  // 0-50 ADX → 0-100 score

// ── Choppiness Index ───────────────────────────────────
float ciHigh = ta.highest(high, choppinessLenInput)
float ciLow  = ta.lowest(low, choppinessLenInput)
float ciAtrSum = math.sum(ta.tr(true), choppinessLenInput)
float ciRange = ciHigh - ciLow
// When range is zero (extreme flat) → max choppiness (100)
// When normal → log10(atrSum / range) / log10(N) * 100
// Guard log10(N): N>=5 by input minval, but defensive max(N,2) anyway.
float chopLogN = math.log10(math.max(choppinessLenInput, 2))
float chopRaw = ciRange <= 0 ? 100.0 : ciAtrSum > 0 ? 100.0 * math.log10(ciAtrSum / ciRange) / chopLogN : 50.0
// Choppiness 0-100: low = trending, high = choppy
// Convert to "trend score": invert and clamp
float chopScore = math.max(0.0, math.min(100.0, 100.0 - chopRaw))

// ── R² (linear regression linearity) ───────────────────
float r2 = rSquared(close, regimeLenInput)
float r2Score = r2 * 100.0

// ── Composite Market Regime Score (0-100) ──────────────
// Weights: ADX 40%, Choppiness 35%, R² 25%
float regimeScore = adxScore * 0.40 + chopScore * 0.35 + r2Score * 0.25

bool isTrending = regimeScore >= REGIME_TRENDING
bool isChoppy   = regimeScore <  REGIME_CHOPPY

string regimeLabel = isTrending ? "Trending" : isChoppy ? "Choppy" : "Mixed"
color  regimeColor = isTrending ? BULL_TEXT  : isChoppy ? BEAR_TEXT  : NEUTRAL_TEXT


// ══════════════════════════════════════════════════════════
// 8. QUALITY SCORE — multi-factor
// ══════════════════════════════════════════════════════════

// ── HTF bias (single security call — saves a slot) ─────
// IMPORTANT: request.security must be called unconditionally on every bar.
// We pass close[1] + ema[1] with lookahead_on — this is the canonical
// non-repaint pattern: read closed HTF bar's value without future leakage.
// Do not "simplify" by removing [1] or toggling lookahead — it will repaint.
string htfRes = htfTfInput == "" ? autoHtf() : htfTfInput
[htfClose, htfEma] = request.security(syminfo.tickerid, htfRes,
     [close[1], ta.ema(close, 50)[1]],
     barmerge.gaps_off, barmerge.lookahead_on)

// htfBull/htfBear are TRUE only when filter is on AND data is valid AND condition holds.
// When filter is off, both are false (semantically correct for dashboard).
bool htfBull = useHtfFilterInput and not na(htfEma) and not na(htfClose) and htfClose > htfEma
bool htfBear = useHtfFilterInput and not na(htfEma) and not na(htfClose) and htfClose < htfEma

// ── Volume confirmation ────────────────────────────────
// volConfirm  → used in Quality Score (semantic: did volume confirm?)
// volStatus   → used in Dashboard (3 states: off / no-data / weak / confirmed)
float volSma = hasVolume ? ta.sma(volume, 20) : na
bool  volConfirm = useVolumeFilterInput and hasVolume and volume > volSma * volMultInput

// ── RSI momentum ───────────────────────────────────────
float rsiVal = nz(ta.rsi(close, 14), 50.0)
bool rsiBullOk = rsiVal > 50
bool rsiBearOk = rsiVal < 50

// ── Breakout strength: how far close pierced the band (capped at 3×ATR) ──
float breakDist = dir == 1 ? close - nz(upperBand[1], close) : dir == -1 ? nz(lowerBand[1], close) - close : 0.0
float breakStrength = atrVal != 0 ? math.min(math.abs(breakDist) / atrVal, 3.0) / 3.0 * 100.0 : 0.0  // 0-100

// ── Compute Quality Score for current signal direction ─
// Weights:
//   HTF bias       30  (full match) / 15 (HTF flat or off) / 0 (against)
//   Volume confirm 20  (full if filter off OR no volume data)
//   RSI momentum   20
//   Regime score   20
//   Break strength 10
calcQualityScore(bool isBuy) =>
    // HTF: gradient, not binary (30 match / 15 off-or-flat / 0 against)
    bool htfDataValid = useHtfFilterInput and not na(htfEma) and not na(htfClose)
    bool htfMatches  = htfDataValid and ((isBuy and htfBull) or (not isBuy and htfBear))
    bool htfAgainst  = htfDataValid and ((isBuy and htfBear) or (not isBuy and htfBull))
    float htfPart = htfMatches ? 30.0 : htfAgainst ? 0.0 : 15.0

    // Volume: full credit when filter off or instrument has no volume data
    float volPart = (not useVolumeFilterInput) or (not hasVolume) ? 20.0 : (volConfirm ? 20.0 : 0.0)

    float rsiPart = (isBuy and rsiBullOk) or (not isBuy and rsiBearOk) ? 20.0 : 0.0
    float regimePart = regimeScore * 0.20  // 0-20
    float breakPart = breakStrength * 0.10 // 0-10
    htfPart + volPart + rsiPart + regimePart + breakPart

float buyQuality  = rawBuy  ? calcQualityScore(true)  : na
float sellQuality = rawSell ? calcQualityScore(false) : na

// Grade resolver
gradeFromScore(float s) =>
    na(s) ? "—" : s >= GRADE_A_THRESHOLD ? "A" : s >= GRADE_B_THRESHOLD ? "B" : "C"


// ══════════════════════════════════════════════════════════
// 9. FINAL SIGNAL LOGIC (with filters)
// ══════════════════════════════════════════════════════════

// Apply filters: minimum quality, hard-skip choppy
bool buyPasses  = rawBuy  and barstate.isconfirmed and (na(buyQuality)  or buyQuality  >= minQualityInput) and not (skipChoppyInput and isChoppy)
bool sellPasses = rawSell and barstate.isconfirmed and (na(sellQuality) or sellQuality >= minQualityInput) and not (skipChoppyInput and isChoppy)

string buyGrade  = gradeFromScore(buyQuality)
string sellGrade = gradeFromScore(sellQuality)

// Choppy warning flag
string chopFlag = isChoppy ? " ⚠" : ""


// ══════════════════════════════════════════════════════════
// 10. RISK MANAGEMENT — preset resolution + SL/TP + BE
// ══════════════════════════════════════════════════════════

// ── Preset multipliers (current-bar inputs, not trade-specific) ──
// Separate ternary chains avoid switch-on-input-string CE10173.
float effSlMult  = riskPresetInput == "Conservative" ? 2.5 : riskPresetInput == "Aggressive" ? 1.0 : riskPresetInput == "Scalping" ? 0.8 : riskPresetInput == "Custom" ? slMultInput  : 1.5
float effTp1Mult = riskPresetInput == "Conservative" ? 1.0 : riskPresetInput == "Aggressive" ? 1.5 : riskPresetInput == "Scalping" ? 0.8 : riskPresetInput == "Custom" ? tp1MultInput : 1.0
float effTp2Mult = riskPresetInput == "Conservative" ? 2.0 : riskPresetInput == "Aggressive" ? 2.5 : riskPresetInput == "Scalping" ? 1.5 : riskPresetInput == "Custom" ? tp2MultInput : 2.0
float effTp3Mult = riskPresetInput == "Conservative" ? 4.0 : riskPresetInput == "Aggressive" ? 4.0 : riskPresetInput == "Scalping" ? 2.0 : riskPresetInput == "Custom" ? tp3MultInput : 3.0

float slDistance = atrVal * effSlMult

// ── Active position state ──────────────────────────────
var float  activeEntry  = na
var float  activeSL     = na
var float  activeTP1    = na
var float  activeTP2    = na
var float  activeTP3    = na
var int    activeDir    = 0
var int    activeBar    = 0       // 0 sentinel — works with the
                                  // ENTRY_BAR_HOLD same-bar guard
                                  // (bar_index - 0 will always exceed 1)
var float  activeQual   = na
var string activeGrade  = ""

// Per-trade snapshots — captured AT ENTRY so a mid-trade preset change
// doesn't invalidate Avg R accounting (each closed trade contributes
// its own-time R values to the rolling sum).
var float  activeTP1Mult = 0.0
var float  activeTP2Mult = 0.0
var float  activeTP3Mult = 0.0

// Per-trade tracking — prevent double-counting TP hits in stats
var bool   tp1Reached    = false
var bool   tp2Reached    = false
var bool   tp3Reached    = false

// Break-even state — true once SL has been pulled to entry after TP1
var bool   beActive      = false


// ── Flip detection ─────────────────────────────────────
// A "flip" = opposite signal fires while a position is still active.
// Captured BEFORE state overwrite so the alert and stats can read
// pre-flip context.
bool buyFlip  = buyPasses  and activeDir == -1
bool sellFlip = sellPasses and activeDir ==  1
bool flipDetected = buyFlip or sellFlip

// Pre-flip context for the flip alert
string flipFromDir = flipDetected ? (activeDir == 1 ? "LONG" : "SHORT") : ""
string flipToDir   = flipDetected ? (buyFlip ? "LONG" : "SHORT") : ""
float  flipFromEntry = flipDetected ? activeEntry : na


// ══════════════════════════════════════════════════════════
// 10a. STATS COUNTERS — declared early for use by closure logic
// ══════════════════════════════════════════════════════════
// All session-scoped (var). Reset on script reload or any input change.
// Outcome stats (W/L/R/BE) are NEW in v1.2.0 — grade-level counters
// from v1.1.0 are preserved alongside.

var int   statTotalSignals = 0
var int   statGradeA       = 0
var int   statGradeB       = 0
var int   statGradeC       = 0
var int   statSlHits       = 0
var int   statTp1Hits      = 0
var int   statTp2Hits      = 0
var int   statTp3Hits      = 0
var int   statFlips        = 0
var int   statBuySignals   = 0
var int   statSellSignals  = 0

// Outcome stats — every closed trade lands in exactly one of {win, loss}.
// statBeSaves is a DIAGNOSTIC sub-counter of wins (subset, not a third bucket).
var int   statWins         = 0
var int   statLosses       = 0
var int   statBeSaves      = 0
var float statRSum         = 0.0   // cumulative realized R-multiple


// ──────────────────────────────────────────────────────────
// Helper: classify a just-closed trade and update outcome stats.
// Called from BOTH the flip-closure path AND the SL/TP3-closure path,
// so the logic lives in one place and stays consistent.
//
// `closeReason` is informational only — doesn't change classification:
//   "sl"   → SL or BE-stop hit (original SL if !beActive, else BE-stop)
//   "tp3"  → TP3 hit (full target reached)
//   "flip" → closed by opposite signal mid-trade
//
// Classification logic (mirrors VWSR):
//   tp1Reached = true  → WIN (regardless of how it closed)
//   tp1Reached = false → LOSS
//
// R-multiple (1/3 partition at each TP — assumes equal sizing per TP):
//   • r1 = (1/3) × activeTP1Mult if tp1Reached (always for WIN)
//   • r2 = (1/3) × activeTP2Mult if tp2Reached
//   • r3 = (1/3) × activeTP3Mult if tp3Reached
//   • Unreached partitions exit at closure price:
//       - tp3 closure: partition that's still in trade missed TP3 ⇒ 0R contribution
//       - flip closure: same — exits at flip price, treated as 0R contribution
//                       (conservative; real fill could be small + or − but for
//                        stats we accept the simplification)
//       - sl closure with tp1Reached: BE-save (closed at entry = 0R for those parts)
//   • LOSS: -1R flat (no partition was reached)
//
// BE save (diagnostic, sub-counter): WIN that closed because BE-stop fired
// (i.e., tp1Reached AND closeReason == "sl" AND beActive was true at bar
// start). High BE-save count = TP1 fills regularly but TP2/TP3 don't.
classifyClosedTrade(string closeReason, bool wasBeAtBarStart) =>
    int outWin = 0
    int outLoss = 0
    int outBeSave = 0
    float outR = 0.0
    if activeDir != 0
        if tp1Reached
            // WIN bucket
            float r1 = (1.0 / 3.0) * activeTP1Mult
            float r2 = tp2Reached ? (1.0 / 3.0) * activeTP2Mult : 0.0
            float r3 = tp3Reached ? (1.0 / 3.0) * activeTP3Mult : 0.0
            outR := r1 + r2 + r3
            outWin := 1
            if closeReason == "sl" and wasBeAtBarStart
                outBeSave := 1
        else
            // LOSS bucket — TP1 never reached; full position exits at -1R
            // (This branch reaches here only if closeReason == "sl" or "flip".
            //  A "tp3" close requires tp1Reached to be true since TP1 is
            //  always closer to entry than TP3 — Pine evaluates tp1Hit on
            //  the same bar before this fn is called, and tp1FirstTouch's
            //  `and not slHit` guard is the only same-bar exception, which
            //  correctly classifies as LOSS here.)
            outR := -1.0
            outLoss := 1
    [outWin, outLoss, outBeSave, outR]


// ══════════════════════════════════════════════════════════
// 10b. POSITION OPEN — signal handling + flip-closure
// ══════════════════════════════════════════════════════════

// If this is a flip bar, the OLD trade closes BEFORE the new one opens.
// classifyClosedTrade is called with activeXxx still holding the OLD
// trade's snapshot (the state-overwrite block below is what changes them).
// Note: flipDetected already requires barstate.isconfirmed (via buyPasses/sellPasses).
if flipDetected
    [w, l, b, r] = classifyClosedTrade("flip", beActive)
    statWins    += w
    statLosses  += l
    statBeSaves += b
    statRSum    += r
    statFlips   += 1
    // NOTE: state vars are intentionally NOT cleared here — the
    // buyPasses/sellPasses block below overwrites them all with fresh
    // values. Order matters: classify → overwrite.

// New position open (also triggered on flip — the classify call above
// already counted the old trade, so this is a clean overwrite)
if buyPasses
    activeEntry := close
    activeSL    := close - slDistance
    activeTP1   := close + slDistance * effTp1Mult
    activeTP2   := close + slDistance * effTp2Mult
    activeTP3   := close + slDistance * effTp3Mult
    activeDir   := 1
    activeBar   := bar_index
    activeQual  := buyQuality
    activeGrade := buyGrade
    // Per-trade snapshots (locked in even if preset changes mid-trade)
    activeTP1Mult := effTp1Mult
    activeTP2Mult := effTp2Mult
    activeTP3Mult := effTp3Mult
    // Reset trade-scoped flags
    tp1Reached := false
    tp2Reached := false
    tp3Reached := false
    beActive   := false

if sellPasses
    activeEntry := close
    activeSL    := close + slDistance
    activeTP1   := close - slDistance * effTp1Mult
    activeTP2   := close - slDistance * effTp2Mult
    activeTP3   := close - slDistance * effTp3Mult
    activeDir   := -1
    activeBar   := bar_index
    activeQual  := sellQuality
    activeGrade := sellGrade
    activeTP1Mult := effTp1Mult
    activeTP2Mult := effTp2Mult
    activeTP3Mult := effTp3Mult
    tp1Reached := false
    tp2Reached := false
    tp3Reached := false
    beActive   := false


// ══════════════════════════════════════════════════════════
// 10c. SAME-BAR GUARDS + HIT DETECTION + BE LOGIC
// ══════════════════════════════════════════════════════════

// Snapshot beActive AT BAR START (before BE-activation block can flip it).
// Used in classify and exit-snapshot blocks below to capture "was BE
// active when we entered this bar?" — distinct from "BE became active
// on this bar".
bool beActiveAtBarStart = beActive

// Snapshot SL BEFORE BE-activation may mutate activeSL.
// effectiveSL is what hit-detection checks against; it's also what
// the SL-hit alert reports. Critical for same-bar TP1+SL resolution
// (the SL hit was against the ORIGINAL SL, not the just-moved BE price).
float effectiveSL = activeSL

// Same-bar entry guard: ignore SL/TP hits on the very first bar of a trade.
// Prevents a hairpin wick from instantly closing a fresh position.
// activeBar == bar_index is the entry bar; we need (bar_index - activeBar) >= 1.
bool canHit = barstate.isconfirmed and activeDir != 0 and (bar_index - activeBar) >= ENTRY_BAR_HOLD

bool slHit  = canHit and (activeDir == 1 ? low  <= effectiveSL : high >= effectiveSL)
bool tp1Hit = canHit and (activeDir == 1 ? high >= activeTP1   : low  <= activeTP1)
bool tp2Hit = canHit and (activeDir == 1 ? high >= activeTP2   : low  <= activeTP2)
bool tp3Hit = canHit and (activeDir == 1 ? high >= activeTP3   : low  <= activeTP3)

// First-touch TP latches — fire each TP only once per trade.
// `and not slHit` makes same-bar SL+TP resolve as a LOSS (conservative
// bias toward stop, mirrors realistic broker behavior on a single wick).
bool tp1FirstTouch = tp1Hit and not tp1Reached and not slHit
bool tp2FirstTouch = tp2Hit and not tp2Reached and not slHit
bool tp3FirstTouch = tp3Hit and not tp3Reached and not slHit

if tp1FirstTouch
    tp1Reached := true
if tp2FirstTouch
    tp2Reached := true
if tp3FirstTouch
    tp3Reached := true

// Break-even activation — on TP1 first touch, move SL to entry.
// `tp1FirstTouch` already includes `not slHit`, so the BE block can't
// fire on a same-bar TP1+SL (which is correctly classified as LOSS).
// From the NEXT bar onward, any wick at entry stops out at BE.
bool beJustActivated = false
if useBreakEvenInput and tp1FirstTouch and not beActive
    activeSL := activeEntry
    beActive := true
    beJustActivated := true


// ══════════════════════════════════════════════════════════
// 10d. EXIT SNAPSHOTS — for alerts and visual updates (survive reset)
// ══════════════════════════════════════════════════════════
// Without these, the alert-build block at end of script reads `na`
// from the (just-reset) activeXxx vars and prints "SL: n/a" instead
// of the value that actually triggered the stop.
//
// exitSL uses effectiveSL specifically: that's the SL value slHit
// checked against. After BE activation that's the original SL, not
// the new BE price — which is what the SL-hit alert should report.
//
// displayTpReached snapshots preserve tp*Reached state so the SL/TP
// visual block (section 13) can still paint the "TP3 ✓" cyan line
// on the bar where TP3 hit triggers closure. Without these, the
// closure block in 10e resets tp3Reached := false BEFORE section 13
// runs, so the visual update would silently skip.

float exitEntry = activeEntry
float exitSL    = effectiveSL
float exitTP1   = activeTP1
float exitTP2   = activeTP2
float exitTP3   = activeTP3
bool  exitBeActive = beActiveAtBarStart  // pre-mutation snapshot

bool displayTp1Reached = tp1Reached
bool displayTp2Reached = tp2Reached
bool displayTp3Reached = tp3Reached


// ══════════════════════════════════════════════════════════
// 10e. CLOSURE on SL or TP3 — classify trade, update stats, reset
// ══════════════════════════════════════════════════════════

bool resetCondition = (slHit or tp3Hit) and activeDir != 0 and barstate.isconfirmed

// Hit counters — first-touch flags already include `not slHit` guard,
// so a same-bar SL+TP doesn't double-count.
if tp1FirstTouch
    statTp1Hits += 1
if tp2FirstTouch
    statTp2Hits += 1
if tp3FirstTouch
    statTp3Hits += 1
if slHit and activeDir != 0 and barstate.isconfirmed
    statSlHits += 1

if resetCondition
    string reason = slHit ? "sl" : "tp3"
    [w, l, b, r] = classifyClosedTrade(reason, beActiveAtBarStart)
    statWins    += w
    statLosses  += l
    statBeSaves += b
    statRSum    += r
    // Reset state
    activeDir      := 0
    activeSL       := na
    activeTP1      := na
    activeTP2      := na
    activeTP3      := na
    activeEntry    := na
    activeBar      := 0
    activeQual     := na
    activeGrade    := ""
    activeTP1Mult  := 0.0
    activeTP2Mult  := 0.0
    activeTP3Mult  := 0.0
    tp1Reached     := false
    tp2Reached     := false
    tp3Reached     := false
    beActive       := false


// ══════════════════════════════════════════════════════════
// 11. PLOTS — trail line + regime background
// ══════════════════════════════════════════════════════════

// ── Trail color resolved by scheme ───────────────────────
// Adaptive: original bull/bear (high-visibility, backward compat)
// Premium Indigo: muted indigo (long) / terracotta (short) — financial-
//   terminal aesthetic, doesn't compete with green TP lines
// Monochrome: theme-aware grey, direction inferred from chart context
color trailColorBull = trailStyleInput == "Premium Indigo" ? TRAIL_INDIGO_LONG  :
     trailStyleInput == "Monochrome"     ? TRAIL_MONO_LONG :
     bullColorInput
color trailColorBear = trailStyleInput == "Premium Indigo" ? TRAIL_INDIGO_SHORT :
     trailStyleInput == "Monochrome"     ? TRAIL_MONO_SHORT :
     bearColorInput
color trailColor = dir == 1 ? trailColorBull : dir == -1 ? trailColorBear : color.new(color.gray, 50)

// ── History limit ──────────────────────────────────────
// trailHistoryBarsInput = 0 means "draw all history" (legacy).
// Otherwise only draw the last N bars — keeps focus on recent action
// and reduces visual clutter when zoomed out.
bool inTrailWindow = trailHistoryBarsInput == 0 or (last_bar_index - bar_index) < trailHistoryBarsInput
float displayedTrail = showTrailInput and inTrailWindow and not na(trailLine) ? trailLine : na

// ── Secondary trail (true dashed, via line.new ring buffer) ──
// Offset direction follows the "risk zone" semantically:
//   Long  → secondary line BELOW main trail (further from price)
//   Short → secondary line ABOVE main trail (further from price)
//
// Why line.new instead of plot(): Pine plot() has no native dashed
// style — only solid/circles/cross/etc. To get TradingView's native
// "Dashed line" look (uniform short dashes with equal gaps), we draw
// per-bar segments via line.new(..., style = line.style_dashed) and
// recycle them through a ring buffer. Bar-to-bar segments stitched
// together render visually identical to a continuous dashed line.

float trailOffsetVal = atrVal * trailOffsetInput
float trailSecondaryNow = trailDoubleInput and showTrailInput and inTrailWindow and not na(trailLine) ?
     (dir == 1 ? trailLine - trailOffsetVal :
      dir == -1 ? trailLine + trailOffsetVal :
      na) : na

color trailColorSecondary = color.new(trailColor, math.min(95, color.t(trailColor) + 20))

// Ring buffer: each bar produces at most one segment (prev_bar → current).
// Size matches the visible trail window; older segments overwritten.
var int dashBufferSize = math.max(1, math.min(490, trailHistoryBarsInput == 0 ? 490 : trailHistoryBarsInput))
var array<line> dashSegments = array.new<line>(dashBufferSize, na)
var int dashWriteIdx = 0

// Draw a dashed segment from previous bar to current when both values
// are valid AND direction is consistent (avoid spurious diagonals
// across direction flips).
float prevSecondary = trailSecondaryNow[1]
int prevDir = nz(dir[1], 0)
bool drawDashSegment = trailDoubleInput and
     not na(trailSecondaryNow) and not na(prevSecondary) and
     dir == prevDir and dir != 0

if drawDashSegment
    // Delete the line in this slot before overwriting (idempotent).
    // On live bar this re-renders same slot with updated coordinates
    // each tick; on confirmed bar the slot is then "locked in" and we
    // advance to the next slot.
    line oldSeg = array.get(dashSegments, dashWriteIdx)
    if not na(oldSeg)
        line.delete(oldSeg)
    line newSeg = line.new(bar_index - 1, prevSecondary, bar_index, trailSecondaryNow,
         color = trailColorSecondary,
         style = line.style_dashed,
         width = 1)
    array.set(dashSegments, dashWriteIdx, newSeg)
    if barstate.isconfirmed
        dashWriteIdx := (dashWriteIdx + 1) % dashBufferSize

// On direction flip: clear all dashed segments so the trail visually
// "resets" with the new direction (avoids ghost dashes from prior trade)
if dir != prevDir and prevDir != 0
    for i = 0 to dashBufferSize - 1
        line ghost = array.get(dashSegments, i)
        if not na(ghost)
            line.delete(ghost)
            array.set(dashSegments, i, na)

plot(displayedTrail, "Synapse Trail",
     color = trailColor, linewidth = trailWidthInput, style = plot.style_linebr)

// Regime background (optional, off by default)
color bgRegimeColor = not showRegimeBgInput ? na :
     isTrending and dir == 1 ? TREND_BG_BULL :
     isTrending and dir == -1 ? TREND_BG_BEAR :
     isChoppy ? CHOPPY_BG :
     na

bgcolor(bgRegimeColor, title = "Regime Background")


// ══════════════════════════════════════════════════════════
// 12. SIGNAL LABELS
// ══════════════════════════════════════════════════════════

// Single-source labels with tooltip and choppy-aware coloring.
// (No plotshape duplication — labels handle everything.)

if showSignalsInput and buyPasses
    string buyHtfStr = useHtfFilterInput ? (htfBull ? "Bullish ✓" : "Bearish ✗") : "off"
    string buyVolStr = not useVolumeFilterInput ? "off" : not hasVolume ? "no data" : volConfirm ? "✓" : "✗"
    string flipPrefix = buyFlip ? "FLIP→LONG\n" : ""
    string tipBuy = flipPrefix + "BUY Signal\nGrade: " + buyGrade + " (" + str.tostring(buyQuality, "#") + "/100)\nRegime: " + regimeLabel + " (" + str.tostring(regimeScore, "#") + ")\nHTF: " + buyHtfStr + "\nVolume: " + buyVolStr + "\nRSI: " + str.tostring(rsiVal, "#.0")
    string buyLabelText = showGradeInput ? "Long ▲ " + buyGrade + chopFlag : "Long ▲" + chopFlag
    label.new(bar_index, low, buyLabelText,
         color     = isChoppy ? neutralColorInput : bullColorInput,
         textcolor = isChoppy ? WARN_LABEL_TEXT : BULL_LABEL_TEXT,
         style     = label.style_label_up,
         size      = signalMarkerSize,
         yloc      = yloc.belowbar,
         tooltip   = tipBuy)

if showSignalsInput and sellPasses
    string sellHtfStr = useHtfFilterInput ? (htfBear ? "Bearish ✓" : "Bullish ✗") : "off"
    string sellVolStr = not useVolumeFilterInput ? "off" : not hasVolume ? "no data" : volConfirm ? "✓" : "✗"
    string flipPrefix = sellFlip ? "FLIP→SHORT\n" : ""
    string tipSell = flipPrefix + "SELL Signal\nGrade: " + sellGrade + " (" + str.tostring(sellQuality, "#") + "/100)\nRegime: " + regimeLabel + " (" + str.tostring(regimeScore, "#") + ")\nHTF: " + sellHtfStr + "\nVolume: " + sellVolStr + "\nRSI: " + str.tostring(rsiVal, "#.0")
    string sellLabelText = showGradeInput ? "Short ▼ " + sellGrade + chopFlag : "Short ▼" + chopFlag
    label.new(bar_index, high, sellLabelText,
         color     = isChoppy ? neutralColorInput : bearColorInput,
         textcolor = isChoppy ? WARN_LABEL_TEXT : BEAR_LABEL_TEXT,
         style     = label.style_label_down,
         size      = signalMarkerSize,
         yloc      = yloc.abovebar,
         tooltip   = tipSell)


// ══════════════════════════════════════════════════════════
// 13. SL/TP LINES & LABELS
// ══════════════════════════════════════════════════════════

var line slLine    = na
var line tp1Line   = na
var line tp2Line   = na
var line tp3Line   = na
var line entryLine = na

var label slLabel    = na
var label tp1Label   = na
var label tp2Label   = na
var label tp3Label   = na
var label entryLabel = na

var bool riskLinesActive = false

// Detect entry bar (used to draw fresh lines/labels). Note: on a flip,
// both the closure logic above AND this entry-bar detect fire on the
// same bar, but `activeBar := bar_index` ensures isEntryBar is true for
// the NEW direction. The old lines get deleted-and-redrawn in the same
// pass via the `(buyPasses or sellPasses)` gate.
bool isEntryBar = activeDir != 0 and activeBar == bar_index

// On new signal — clear old, draw new
if (buyPasses or sellPasses) and showSlTpInput
    line.delete(slLine)
    line.delete(tp1Line)
    line.delete(tp2Line)
    line.delete(tp3Line)
    line.delete(entryLine)
    label.delete(slLabel)
    label.delete(tp1Label)
    label.delete(tp2Label)
    label.delete(tp3Label)
    label.delete(entryLabel)

    int x1 = bar_index
    int x2 = bar_index + LINE_FORWARD_BARS

    entryLine := line.new(x1, activeEntry, x2, activeEntry, color = ENTRY_COLOR, style = entryLineStyle, width = 1)
    slLine    := line.new(x1, activeSL,    x2, activeSL,    color = SL_COLOR,    style = slLineStyle,    width = 1)
    tp1Line   := line.new(x1, activeTP1,   x2, activeTP1,   color = TP1_COLOR,   style = tpLineStyle,    width = 1)
    tp2Line   := line.new(x1, activeTP2,   x2, activeTP2,   color = TP2_COLOR,   style = tpLineStyle,    width = 1)
    tp3Line   := line.new(x1, activeTP3,   x2, activeTP3,   color = TP3_COLOR,   style = tpLineStyle,    width = 1)

    if showSlTpLabelsInput
        int lblX = x2 + LABEL_OFFSET_BARS
        // Format prices with optional "(+0.42%)" suffix
        string entryS = str.tostring(activeEntry, format.mintick)
        string slS    = fmtPrice(activeSL)  + formatPctFromEntry(activeSL,  activeEntry)
        string tp1S   = fmtPrice(activeTP1) + formatPctFromEntry(activeTP1, activeEntry)
        string tp2S   = fmtPrice(activeTP2) + formatPctFromEntry(activeTP2, activeEntry)
        string tp3S   = fmtPrice(activeTP3) + formatPctFromEntry(activeTP3, activeEntry)

        entryLabel := label.new(lblX, activeEntry, "ENTRY " + entryS,
             color = ENTRY_COLOR, textcolor = LABEL_TEXT,
             style = label.style_label_left, size = labelSize)
        slLabel := label.new(lblX, activeSL, "SL " + slS,
             color = SL_COLOR, textcolor = LABEL_TEXT,
             style = label.style_label_left, size = labelSize)
        tp1Label := label.new(lblX, activeTP1, "TP1 " + tp1S,
             color = TP_LABEL_COLOR, textcolor = LABEL_TEXT,
             style = label.style_label_left, size = labelSize)
        tp2Label := label.new(lblX, activeTP2, "TP2 " + tp2S,
             color = TP_LABEL_COLOR, textcolor = LABEL_TEXT,
             style = label.style_label_left, size = labelSize)
        tp3Label := label.new(lblX, activeTP3, "TP3 " + tp3S,
             color = TP_LABEL_COLOR, textcolor = LABEL_TEXT,
             style = label.style_label_left, size = labelSize)

    riskLinesActive := true

// ── TP-hit visuals — line turns solid cyan + label gets ✓ ──
// Use display-snapshot flags so the visual update still happens on
// the bar where TP3 closes the trade (closure resets tp*Reached := false
// in section 10e, which executes before this block). For TP1/TP2, the
// snapshot is identical to the live flag (they don't trigger closure),
// but using the same source-of-truth keeps the code uniform.
// Use exit-snapshot prices (exitTP*) so labels show the actual hit
// price after closure resets activeTP* to na.
if showSlTpInput and not na(tp1Line) and displayTp1Reached
    line.set_color(tp1Line, TP_HIT_COLOR)
    line.set_style(tp1Line, line.style_solid)
    if showSlTpLabelsInput and not na(tp1Label)
        label.set_text(tp1Label, "TP1 ✓ " + fmtPrice(exitTP1) + formatPctFromEntry(exitTP1, exitEntry))
        label.set_color(tp1Label, TP_HIT_COLOR)
if showSlTpInput and not na(tp2Line) and displayTp2Reached
    line.set_color(tp2Line, TP_HIT_COLOR)
    line.set_style(tp2Line, line.style_solid)
    if showSlTpLabelsInput and not na(tp2Label)
        label.set_text(tp2Label, "TP2 ✓ " + fmtPrice(exitTP2) + formatPctFromEntry(exitTP2, exitEntry))
        label.set_color(tp2Label, TP_HIT_COLOR)
if showSlTpInput and not na(tp3Line) and displayTp3Reached
    line.set_color(tp3Line, TP_HIT_COLOR)
    line.set_style(tp3Line, line.style_solid)
    if showSlTpLabelsInput and not na(tp3Label)
        label.set_text(tp3Label, "TP3 ✓ " + fmtPrice(exitTP3) + formatPctFromEntry(exitTP3, exitEntry))
        label.set_color(tp3Label, TP_HIT_COLOR)

// ── BE-active visualization — dim SL, mark Entry as "→ SL (BE)" ──
// activeSL itself was already moved to entry by the BE logic in section 10.
if showSlTpInput and beActive and activeDir != 0
    if not na(slLine)
        line.set_color(slLine, color.new(SL_COLOR, 70))
    if showSlTpLabelsInput
        if not na(slLabel)
            label.set_color(slLabel, color.new(SL_COLOR, 70))
        if not na(entryLabel)
            string entryS = str.tostring(activeEntry, format.mintick)
            label.set_text(entryLabel, "ENTRY " + entryS + "  → SL (BE)")
            label.set_color(entryLabel, BE_COLOR)

// Extend active lines forward to current bar
if activeDir != 0 and showSlTpInput and not na(slLine)
    int newX2 = bar_index + LINE_UPDATE_BARS
    int newLblX = newX2 + LABEL_OFFSET_BARS
    line.set_x2(slLine,    newX2)
    line.set_x2(tp1Line,   newX2)
    line.set_x2(tp2Line,   newX2)
    line.set_x2(tp3Line,   newX2)
    line.set_x2(entryLine, newX2)
    if showSlTpLabelsInput and not na(slLabel)
        label.set_x(slLabel,    newLblX)
        label.set_x(tp1Label,   newLblX)
        label.set_x(tp2Label,   newLblX)
        label.set_x(tp3Label,   newLblX)
        label.set_x(entryLabel, newLblX)

// On position close — clean up once.
// Note: cleanup runs regardless of showSlTpInput so lines don't leak
// on chart if user disables the toggle mid-trade. line.delete is safe
// even if the line ref is na.
if activeDir == 0 and riskLinesActive
    line.delete(slLine)
    line.delete(tp1Line)
    line.delete(tp2Line)
    line.delete(tp3Line)
    line.delete(entryLine)
    label.delete(slLabel)
    label.delete(tp1Label)
    label.delete(tp2Label)
    label.delete(tp3Label)
    label.delete(entryLabel)
    riskLinesActive := false


// ══════════════════════════════════════════════════════════
// 14. SIGNAL-LEVEL STATS — tallies on signal moment
// ══════════════════════════════════════════════════════════
// Counter variables are declared in section 10a alongside the trade
// outcome stats. This section ONLY tallies signal-fire counters
// (total signals, buy/sell split, grade A/B/C). They fire on signal
// moment regardless of whether a trade ends up being opened.
//
// Outcome stats (W/L/R/BE), flips, and hit counts are tallied inside
// section 10's closure logic (alongside the lifecycle).

// Tally on signal fire — grade is fresh at this moment (before
// activeGrade may be reset by closure).
// Note: buyPasses/sellPasses already require barstate.isconfirmed.
if buyPasses
    statTotalSignals += 1
    statBuySignals   += 1
    if buyGrade == "A"
        statGradeA += 1
    else if buyGrade == "B"
        statGradeB += 1
    else
        statGradeC += 1

if sellPasses
    statTotalSignals += 1
    statSellSignals  += 1
    if sellGrade == "A"
        statGradeA += 1
    else if sellGrade == "B"
        statGradeB += 1
    else
        statGradeC += 1

// ── Derived metrics ────────────────────────────────────
// Closed trades = wins + losses (flips, SL, and TP3 all flow into one
// of these via classifyClosedTrade in section 10).
int   closedTrades = statWins + statLosses
float winRate      = closedTrades > 0 ? statWins / float(closedTrades) * 100.0 : 0.0
float avgR         = closedTrades > 0 ? statRSum / float(closedTrades) : 0.0


// ══════════════════════════════════════════════════════════
// 15. UNIFIED DASHBOARD — single table with toggleable sections
// ══════════════════════════════════════════════════════════
//
// Combines what was previously two separate tables (Dashboard and
// Statistics) into one with section dividers. Each section has its
// own toggle (showTradeSectionInput / showMarketSectionInput /
// showStatsInput); the master `showDashInput` switches everything off.
//
// PERF: all display-only prep is gated behind
// `if showDashInput and barstate.islast`. Functional values used
// elsewhere (currentRR by alerts) stay outside the gate.

dashPos = resolveDashPos(dashPosStr)

// Real R:R from active levels — needed by alerts; computed every bar.
float currentRR = activeDir != 0 and activeEntry != activeSL ? math.abs(activeTP1 - activeEntry) / math.abs(activeEntry - activeSL) : 0.0

// ── var-declared display state, recomputed inside the gate ─────
// Trade section
var string dashDirGrade  = "FLAT"
var color  dashDirCol    = na
var string dashSl        = "—"
var string dashTp1       = "—"
var string dashTp2       = "—"
var string dashTp3       = "—"
var color  dashSlCol     = na
var color  dashTp1Col    = na
var color  dashTp2Col    = na
var color  dashTp3Col    = na
var string dashRiskRR    = "—"
var color  dashRiskCol   = na
var string dashBars      = "—"

// Market section
var string dashRegime    = ""
var string dashHtfBias   = "off"
var color  dashHtfCol    = na
var string dashVol       = "off"
var color  dashVolCol    = na
var string dashRsi       = "0"
var color  dashRsiCol    = na
var string dashVolReg    = "—"

// Statistics section
var string dashSignals   = "0"
var string dashBuySell   = "0 / 0"
var string dashClosed    = "0"
var string dashWL        = "0 / 0"
var string dashWinRate   = "—"
var string dashAvgR      = "—"
var string dashBeSaves   = "0"
var string dashFlips     = "0"
var color  winRateCol    = na
var color  avgRCol       = na

if showDashInput and barstate.islast
    // ── Prep Trade section ──
    string gradeSuffix = activeGrade != "" ? " (" + activeGrade + ")" : ""
    dashDirGrade := activeDir == 1 ? "LONG" + gradeSuffix : activeDir == -1 ? "SHORT" + gradeSuffix : "FLAT"
    dashDirCol   := activeDir == 1 ? BULL_TEXT : activeDir == -1 ? BEAR_TEXT : TEXT_MUTED

    dashSl  := activeDir != 0 ? (beActive ? "BE @ " : "") + fmtPrice(activeSL)  : "—"
    dashTp1 := activeDir != 0 ? (tp1Reached ? "✓ " : "") + fmtPrice(activeTP1) : "—"
    dashTp2 := activeDir != 0 ? (tp2Reached ? "✓ " : "") + fmtPrice(activeTP2) : "—"
    dashTp3 := activeDir != 0 ? (tp3Reached ? "✓ " : "") + fmtPrice(activeTP3) : "—"

    dashSlCol  := activeDir == 0 ? TEXT_MUTED : beActive ? BE_COLOR : SL_COLOR
    dashTp1Col := activeDir == 0 ? TEXT_MUTED : tp1Reached ? TP_HIT_COLOR : TP_LABEL_COLOR
    dashTp2Col := activeDir == 0 ? TEXT_MUTED : tp2Reached ? TP_HIT_COLOR : TP_LABEL_COLOR
    dashTp3Col := activeDir == 0 ? TEXT_MUTED : tp3Reached ? TP_HIT_COLOR : TP_LABEL_COLOR

    float riskPctVal = activeDir != 0 and activeEntry != 0 ? math.abs(activeEntry - activeSL) / activeEntry * 100.0 : 0.0
    string riskPctStr = activeDir != 0 ? str.tostring(riskPctVal, "#.##") + "%" : "—"
    string rrStr      = activeDir != 0 ? str.tostring(currentRR, "#.#") + "R" : "—"
    // R:R gauge — fill % of currentRR against a 3R "full" target.
    // 3R = TP3 in Balanced preset; reaching it = gauge full. >3R clamps.
    string rrGauge = activeDir != 0 ? buildGauge(currentRR, 3.0, 6) : ""
    dashRiskRR  := activeDir != 0 ? rrGauge + "  " + riskPctStr + " / " + rrStr : "—"
    dashRiskCol := riskPctVal > 3.0 ? BEAR_TEXT : riskPctVal > 1.0 ? NEUTRAL_TEXT : riskPctVal > 0 ? BULL_TEXT : TEXT_MUTED

    int barsInTrade = activeDir != 0 and activeBar > 0 ? bar_index - activeBar : 0
    dashBars := activeDir != 0 ? str.tostring(barsInTrade) : "—"

    // ── Prep Market section ──
    // Regime with unicode gauge: visual fill (8 cells) = regimeScore/100.
    // Reads at a glance — no need to interpret the raw 0-100 number.
    dashRegime  := regimeLabel + "  " + buildGauge(regimeScore, 100, 8)
    dashHtfBias := not useHtfFilterInput ? "off" : htfBull ? "Bullish" : htfBear ? "Bearish" : "Flat"
    dashHtfCol  := not useHtfFilterInput ? TEXT_MUTED : htfBull ? BULL_TEXT : htfBear ? BEAR_TEXT : NEUTRAL_TEXT
    dashVol     := not useVolumeFilterInput ? "off" : not hasVolume ? "no data" : volConfirm ? "Confirmed" : "Weak"
    dashVolCol  := not useVolumeFilterInput or not hasVolume ? TEXT_MUTED : volConfirm ? BULL_TEXT : NEUTRAL_TEXT
    dashRsi     := str.tostring(rsiVal, "#.0")
    dashRsiCol  := rsiVal > 60 ? BULL_TEXT : rsiVal < 40 ? BEAR_TEXT : TEXT_MUTED
    dashVolReg  := useAdaptiveMultInput ?
         str.tostring(atrVal, format.mintick) + " | " + str.tostring(volRank, "#") + "% (×" + str.tostring(multAdjust, "#.##") + ")" :
         str.tostring(atrVal, format.mintick) + " | (off)"

    // ── Prep Statistics section ──
    // Total signals + grade breakdown in one cell for compactness:
    // "12 (A:3 B:5 C:4)"
    dashSignals := str.tostring(statTotalSignals) +
         " (A:" + str.tostring(statGradeA) +
         " B:" + str.tostring(statGradeB) +
         " C:" + str.tostring(statGradeC) + ")"
    dashBuySell := str.tostring(statBuySignals) + " / " + str.tostring(statSellSignals)
    dashClosed  := str.tostring(closedTrades)
    dashWL      := str.tostring(statWins) + " / " + str.tostring(statLosses)
    dashWinRate := closedTrades > 0 ? str.tostring(winRate, "#.#") + "%" : "—"
    dashAvgR    := closedTrades > 0 ? str.tostring(avgR, "+0.00;-0.00") + "R" : "—"
    dashBeSaves := statWins > 0 ?
         str.tostring(statBeSaves) + " (" + str.tostring(statBeSaves / float(statWins) * 100.0, "#") + "%)" :
         str.tostring(statBeSaves)
    dashFlips   := str.tostring(statFlips)

    winRateCol := closedTrades == 0 ? TEXT_MUTED :
         winRate >= 55.0 ? BULL_TEXT :
         winRate >= 45.0 ? NEUTRAL_TEXT :
         BEAR_TEXT
    avgRCol := closedTrades == 0 ? TEXT_MUTED :
         avgR > 0 ? BULL_TEXT :
         avgR < 0 ? BEAR_TEXT :
         TEXT_MUTED

    // ── Compute table size ──
    // 1 (header) + 1 (ver footer) + per-section: 1 (sec header) + N (data rows)
    //
    // ── Dynamic section header text ──
    // Each section header carries one piece of live context, so the
    // divider isn't just decoration — it's an at-a-glance summary.
    int barsInTradeNow = activeDir != 0 and activeBar > 0 ? bar_index - activeBar : 0
    string tradeHeaderTxt = activeDir == 0 ?
         "───  Trade · FLAT  ───" :
         "───  Trade · " + (activeDir == 1 ? "LONG" : "SHORT") + " · " + str.tostring(barsInTradeNow) + " bars  ───"
    string marketHeaderTxt = "───  Market · " + regimeLabel + "  ───"
    string statsHeaderTxt = closedTrades == 0 ?
         "───  Statistics · no trades  ───" :
         "───  Statistics · " + str.tostring(closedTrades) + " trades  ───"

    // ── Compute table size ──
    // 1 (header) + 1 (ver footer) + per-section: 1 (sec header) + N (data rows)
    //
    // Trade:  1 sec-header + 7 data rows (Direction, SL, TP1, TP2, TP3, Risk/R:R, Bars) = 8
    // Market: 1 sec-header + 5 data rows (Regime, HTF, Volume, RSI, ATR|Vol)            = 6
    // Stats:  1 sec-header + 8 data rows (Signals, Buy/Sell, Closed, W/L, WR, AvgR, BE, Flips) = 9
    //
    // Pine table.new takes the row count at creation. `var table`
    // re-initializes on any input change (including section toggles),
    // so the count always matches the current display config.
    int tradeRows  = showTradeSectionInput  ? 8 : 0
    int marketRows = showMarketSectionInput ? 6 : 0
    int statsRows  = showStatsInput         ? 9 : 0
    int totalRows  = 2 + tradeRows + marketRows + statsRows

    var table dashTable = table.new(dashPos, 2, totalRows,
         bgcolor      = TABLE_BG,
         border_color = TABLE_BORDER,
         border_width = 1,
         frame_color  = TABLE_BORDER,
         frame_width  = 1)

    // ── Render ──
    int r = 0

    // Main header — diamond glyph adds subtle premium accent without emoji
    table.cell(dashTable, 0, r, "◆  SYNAPSE TRAIL PRO",
         text_color = HEADER_TEXT, bgcolor = HEADER_BG, text_size = size.small,
         text_halign = text.align_center)
    table.merge_cells(dashTable, 0, r, 1, r)
    r += 1

    // Section: Trade
    if showTradeSectionInput
        table.cell(dashTable, 0, r, tradeHeaderTxt,
             text_color = TEXT_MUTED, bgcolor = TABLE_ROW_ALT, text_size = size.tiny,
             text_halign = text.align_center)
        table.merge_cells(dashTable, 0, r, 1, r)
        r += 1

        table.cell(dashTable, 0, r, "Direction", text_color = TEXT_MUTED, text_size = size.small)
        table.cell(dashTable, 1, r, dashDirGrade, text_color = dashDirCol, text_size = size.small)
        r += 1

        table.cell(dashTable, 0, r, "SL", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        table.cell(dashTable, 1, r, dashSl, text_color = dashSlCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        r += 1

        table.cell(dashTable, 0, r, "TP1", text_color = TEXT_MUTED, text_size = size.small)
        table.cell(dashTable, 1, r, dashTp1, text_color = dashTp1Col, text_size = size.small)
        r += 1

        table.cell(dashTable, 0, r, "TP2", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        table.cell(dashTable, 1, r, dashTp2, text_color = dashTp2Col, text_size = size.small, bgcolor = TABLE_ROW_ALT)

        r += 1
        table.cell(dashTable, 0, r, "TP3", text_color = TEXT_MUTED, text_size = size.small)
        table.cell(dashTable, 1, r, dashTp3, text_color = dashTp3Col, text_size = size.small)
        r += 1

        table.cell(dashTable, 0, r, "Risk / R:R", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT,
             tooltip = "Risk %: distance from entry to SL (BE-aware).\n" +
                       "R:R: reward-to-risk ratio at TP1.\n" +
                       "Gauge: current R:R progress vs 3R target (TP3 in Balanced preset).")
        table.cell(dashTable, 1, r, dashRiskRR, text_color = dashRiskCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        r += 1

        table.cell(dashTable, 0, r, "Bars in Trade", text_color = TEXT_MUTED, text_size = size.small)
        table.cell(dashTable, 1, r, dashBars, text_color = TEXT_COLOR, text_size = size.small)
        r += 1

    // Section: Market
    if showMarketSectionInput
        table.cell(dashTable, 0, r, marketHeaderTxt,
             text_color = TEXT_MUTED, bgcolor = TABLE_ROW_ALT, text_size = size.tiny,
             text_halign = text.align_center)
        table.merge_cells(dashTable, 0, r, 1, r)
        r += 1

