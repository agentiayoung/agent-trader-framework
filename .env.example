# Agent Trader — Environment Variables
# Copy to .env and fill in the values

# ── OpenRouter (LLM) ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxx

# ── Polymarket ────────────────────────────────────────────────────
# Get API keys: dérivelés via EIP-712 signing de ton wallet Polygon
# Guide: https://docs.polymarket.com/#api-keys
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=0x...        # Wallet Polygon private key
POLYMARKET_FUNDER=0x...             # Funder address (usually same as wallet)
POLYMARKET_PAPER_MODE=1             # 1 = paper trading (orders signed but NOT sent), empty = live

# ── Hyperliquid ───────────────────────────────────────────────────
# Create wallet: any Ethereum/Arbitrum wallet works
# Testnet: https://app.hyperliquid-testnet.xyz
HYPERLIQUID_PRIVATE_KEY=0x...       # Wallet Arbitrum private key
HYPERLIQUID_ADDRESS=0x...           # Public address
HYPERLIQUID_TESTNET=1               # 1 = testnet, empty = mainnet

# ── Bybit (ccxt, demo trading by default) ────────────────────────
# Demo trading keys: app.bybit.com -> Demo Trading -> API. (Separate from mainnet keys.)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_DEMO=1                        # 1 (default) = demo trading, 0 = mainnet (live funds!)
BYBIT_TESTNET=                      # 1 = classic testnet.bybit.com instead of demo

# ── Telegram Bots ─────────────────────────────────────────────────
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN_POLYMARKET=
TELEGRAM_BOT_TOKEN_HYPERLIQUID=

# the maintainer's Telegram chat ID (get via @userinfobot)
TELEGRAM_CHAT_ID=

# ── Risk Management ──────────────────────────────────────────────
RM_MAX_POSITION_USDC=100        # Max USDC per single trade
RM_MAX_TOTAL_EXPOSURE_USDC=1000 # Max total open exposure
RM_MAX_LEVERAGE=5               # Default max leverage (hard cap: 10x)
RM_DAILY_LOSS_PCT=5             # Halt trading if daily loss > X%
RM_WEEKLY_LOSS_PCT=10           # Halt trading if weekly loss > X%

# ── Supabase (Trade Logging) ─────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx

# ── TradingView (webhook signals → hyperliquid) ──────────────────
# Clé secrète partagée entre l'alerte TradingView (champ "key" ou "secret") et le listener.
# Générer une valeur forte, ex: openssl rand -hex 24
# Utilisée par /webhook/tradingview ET /webhook/confluence.
WEBHOOK_SECRET=
TV_WEBHOOK_PORT=8088                  # Port d'écoute du service FastAPI (host)
TV_SIGNALS_DIR=/data/.openclaw/workspace-hyperliquid/signals  # Inbox lue par l'agent

# ── Signal Executor (tradingview/executor) ───────────────────────
# Worker qui lit l'inbox signals/ et place les brackets (HL / Bybit).
EXECUTOR_LIVE=0                       # 0 = dry-run (défaut, aucun ordre), 1 = exécution réelle
EXECUTOR_MAX_PER_CYCLE=2             # Max signaux traités par cycle
EXECUTOR_POLL_SEC=15                # Intervalle de polling en mode --watch (secondes)

# ── Risk management routines (circuit breaker) ───────────────────
RM_DAILY_LOSS_PCT=5                  # Halt nouveaux trades si perte jour > X%
RM_MAX_DRAWDOWN_PCT=10               # Halt si drawdown depuis high-water > X%
RM_RISK_PCT_A=5                      # % equity risque par trade A-tier (sizing dynamique)
RM_RISK_PCT_B=2.5                    # % equity risque par trade B-tier
CORR_MAX_SAME_SIDE=3                 # Max positions meme sens (cap correlation crypto/beta BTC)

# ── Scanner multi-paires (trade-journal/scan.js) ─────────────────
SCAN_WATCHLIST=BTC,ETH,SOL,BNB,XRP,DOGE,AVAX,LINK,ADA,SUI,LTC,DOT,TON,NEAR

# ── Notifications Telegram routines ──────────────────────────────
# Créer un bot via @BotFather, chat ID via @userinfobot
TELEGRAM_BOT_TOKEN_ROUTINE=          # Token du bot de notif (fallback: _HYPERLIQUID)
# (TELEGRAM_CHAT_ID déjà défini plus haut)

# ── Confluence Engine (multi-indicateurs signal-only) ───────────
# Bot Telegram dédié aux recommandations confluence (séparé des bots agent-trader).
# Créer via @BotFather. Chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN_CONFLUENCE=
TELEGRAM_CHAT_ID_CONFLUENCE=
# Dossier où le webhook persiste les alertes brutes (audit + replay backtest).
CONFLUENCE_RAW_DIR=/data/.openclaw/workspace-hyperliquid/confluence_raw
